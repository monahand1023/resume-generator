# =============================================================================
# Resume Customizer — backend configuration
# Copy to `.env` and uncomment what you need. Everything has a sensible default
# (see config.js), so an empty .env works for local dev.
# =============================================================================

# --- Server ------------------------------------------------------------------
PORT=3000
# Comma-separated allowlist of CORS origins. Unset/empty = allow all (dev).
# CORS_ORIGIN=https://yourdomain.com
# Chromium path for Puppeteer (set in Docker/CI; auto-detected locally).
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# --- AI provider keys --------------------------------------------------------
# The WEB UI takes provider keys in the browser (never sent to the server).
# These env vars are used by the CLI (`npm run customize`) only:
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Amazon Bedrock (Nova) provider ------------------------------------------
# Bedrock uses server-side AWS credentials (AWS_PROFILE / static keys / IAM role),
# not a user key. It is offered only when AWS looks configured; force on/off:
# BEDROCK_ENABLED=true
# BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
# AWS_REGION=us-west-2            # or BEDROCK_REGION
# BEDROCK_MAX_TOKENS=2000
# BEDROCK_MAX_ATTEMPTS=3

# --- Per-provider model overrides --------------------------------------------
# OPENAI_MODEL=gpt-4
# OPENAI_MAX_TOKENS=2000
# GEMINI_MODEL=gemini-1.5-pro-latest
# GEMINI_MAX_TOKENS=8000
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
# CLAUDE_MAX_TOKENS=3000

# --- Input limits ------------------------------------------------------------
# MAX_FILE_SIZE_BYTES=10485760   # 10 MB upload cap
# MAX_RESUME_CHARS=50000         # parsed resume truncated before the AI
# MAX_JOB_URL_LENGTH=2000
# JD_MAX_LENGTH=8000             # scraped job description truncated before the AI

# --- Timeouts (ms) -----------------------------------------------------------
# AI_TIMEOUT_MS=60000            # per AI call
# SCRAPE_TIMEOUT_MS=30000        # job-page navigation
# JOB_STREAM_TIMEOUT_MS=120000   # SSE stream max duration

# --- Job queue + result cache ------------------------------------------------
# JOB_TTL_MS=3600000             # in-memory job retention (1h)
# JOB_CLEANUP_INTERVAL_MS=300000 # cleanup sweep interval (5m)
# RESULT_CACHE_TTL_MS=86400000   # reuse identical results for 24h (in-memory)
# RESULT_CACHE_MAX_ENTRIES=50

# --- Rate limits -------------------------------------------------------------
# RATE_LIMIT_GLOBAL_MAX=100      # per 15 min, all endpoints
# RATE_LIMIT_RESUME_MAX=10       # per hour, /api/customize-resume
# RATE_LIMIT_PREVIEW_MAX=30      # per hour, /api/preview

# --- Logging -----------------------------------------------------------------
# LOG_LEVEL=info                 # debug | info | warn | error | silent
